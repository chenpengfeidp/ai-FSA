# Local Compose interpolation values only.
FAS_POSTGRES_DB=fas_local
FAS_POSTGRES_USER=fas_local
FAS_POSTGRES_PASSWORD=change_me_local_only
FAS_API_PUBLISHED_PORT=3001
FAS_WEB_PUBLISHED_PORT=3000

# API PostgreSQL readiness (P.1 / MF-11). Compose injects a service URL automatically.
# Local `pnpm dev:api` defaults to live mode against this URL; use stub without Postgres.
DATABASE_URL=postgresql://fas_local:change_me_local_only@127.0.0.1:5432/fas_local
# DATABASE_CLIENT_MODE=live|stub

# Evidence repository (P.2). Default memory keeps analyze offline.
# For postgres: migrate first, then set mode=postgres with DATABASE_CLIENT_MODE=live.
# DATABASE_URL=... pnpm --filter @fas/database prisma:migrate
# EVIDENCE_REPOSITORY_MODE=memory|postgres
EVIDENCE_REPOSITORY_MODE=memory

# ---------------------------------------------------------------------------
# Odds / Match Center (copy these into root `.env` — never commit `.env`)
# ---------------------------------------------------------------------------
# ODDS_PROVIDER_MODE=recorded|live|fixture
#   recorded = local cassette (often Aug demo dates); no API credits
#   live     = The Odds API multi-league upcoming + scores; needs THE_ODDS_API_KEY
#   fixture  = fixture seeds only
ODDS_PROVIDER_MODE=recorded
# THE_ODDS_API_KEY=
# THE_ODDS_API_BASE_URL=https://api.the-odds-api.com

# ODDS_SPORT_KEYS — comma-separated The Odds API sport keys (no spaces needed).
# Omit the variable entirely to use the code default (big-5 + K/J + Nordics +
# Portugal + UCL/Europa/Conference). Each key costs ~1 credit for scores and
# ~1 credit for upcoming odds per Match Center refresh (concurrency 3).
# Too many keys → 429 / quota exhaustion → API falls back to recorded cassette.
#
# Narrow (fewer credits — good when quota is tight):
# ODDS_SPORT_KEYS=soccer_korea_kleague1,soccer_japan_j_league,soccer_sweden_allsvenskan,soccer_finland_veikkausliiga,soccer_norway_eliteserien,soccer_uefa_champs_league,soccer_uefa_champs_league_qualification,soccer_uefa_europa_league
#
# Widen (add big-5 / Portugal / Conference as needed):
# ODDS_SPORT_KEYS=soccer_epl,soccer_spain_la_liga,soccer_italy_serie_a,soccer_germany_bundesliga,soccer_france_ligue_one,soccer_portugal_primeira_liga,soccer_korea_kleague1,soccer_japan_j_league,soccer_sweden_allsvenskan,soccer_finland_veikkausliiga,soccer_norway_eliteserien,soccer_uefa_champs_league,soccer_uefa_champs_league_qualification,soccer_uefa_europa_league,soccer_uefa_europa_conference_league
#
# After editing ODDS_* in `.env`: restart `pnpm dev:api` (config is loaded at boot).
# Sport key catalog: https://the-odds-api.com/sports-odds-data/sports-apis.html

# Pinned calibration artifact consumed by Analysis (A.1). Default population demo.
# CALIBRATION_ARTIFACT=identity|population_demo_v1
CALIBRATION_ARTIFACT=population_demo_v1
