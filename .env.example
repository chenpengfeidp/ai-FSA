# Local Compose interpolation values only.
FAS_POSTGRES_DB=fas_local
FAS_POSTGRES_USER=fas_local
FAS_POSTGRES_PASSWORD=change_me_local_only
FAS_API_PUBLISHED_PORT=3001
FAS_WEB_PUBLISHED_PORT=3000

# Odds overlay + Match Center upcoming board (B.1/B.2/C.1). Default recorded is offline.
# For live: copy to .env (never commit), set mode=live and your key from
# https://the-odds-api.com/#get-access — rotate any key that was pasted into chat.
# Live Match Center primes scores (daysFrom=3, ~2 credits) then upcoming odds (~1 credit).
# ODDS_PROVIDER_MODE=recorded|live|fixture
ODDS_PROVIDER_MODE=recorded
# THE_ODDS_API_KEY=
# THE_ODDS_API_BASE_URL=https://api.the-odds-api.com
