{
  "name": "ai-fsa",
  "version": "0.0.0",
  "private": true,
  "description": "Evidence-first AI football analysis platform",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": "24.18.0",
    "pnpm": "11.13.0"
  },
  "scripts": {
    "boundaries": "depcruise --config dependency-cruiser.config.cjs apps packages",
    "boundaries:test": "node scripts/validate-boundary-fixture.mjs",
    "build": "turbo run build",
    "check": "biome check .",
    "dev:api": "pnpm exec turbo run build --filter=@fas/api... && pnpm --filter @fas/api dev",
    "dev:web": "pnpm --filter @fas/web dev",
    "dev:worker": "pnpm --filter @fas/config build && pnpm --filter @fas/worker dev",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "prepare": "node scripts/install-git-hooks.mjs",
    "prisma:generate": "pnpm --filter @fas/database generate",
    "prisma:validate": "pnpm --filter @fas/database prisma:validate",
    "quality": "pnpm check && pnpm boundaries && pnpm boundaries:test",
    "test": "turbo run test",
    "toolchain:check": "node scripts/validate-toolchain.mjs",
    "toolchain:test": "node --test scripts/toolchain-enforcement.test.mjs",
    "typecheck": "turbo run typecheck",
    "workspace:check": "node scripts/validate-workspace.mjs && pnpm --recursive list --depth -1",
    "validate": "pnpm toolchain:check && pnpm toolchain:test && pnpm workspace:check && pnpm prisma:validate && pnpm prisma:generate && pnpm quality && pnpm typecheck && pnpm test && pnpm build"
  },
  "lint-staged": {
    "*.{js,jsx,mjs,cjs,ts,tsx,mts,cts,json,jsonc,css}": "biome check --write --no-errors-on-unmatched"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@fas/tsconfig": "workspace:*",
    "dependency-cruiser": "18.1.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "turbo": "2.10.5",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
