{
  "name": "@fas/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "pnpm generate && tsc --project tsconfig.json",
    "generate": "prisma generate --config prisma.config.ts",
    "prisma:validate": "prisma validate --config prisma.config.ts",
    "test": "pnpm generate && vitest run --root ../.. --config vitest.config.ts --project database",
    "typecheck": "pnpm generate && tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@fas/tsconfig": "workspace:*",
    "@types/pg": "8.20.0",
    "prisma": "7.8.0",
    "typescript": "6.0.3"
  }
}
